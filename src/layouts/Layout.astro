---
const year = new Date().getFullYear();
import Nav from '../components/Nav.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';
import site from '../data/site.json';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/src/styles.css" />
  </head>
  <body class="antialiased">
    <Nav />
    <main class="container mx-auto py-8">
      <slot />
    </main>
    <slot name="footer" />
    <footer class="mt-12 text-center text-sm muted">© {year} {site.title}</footer>
  </body>
</html>
