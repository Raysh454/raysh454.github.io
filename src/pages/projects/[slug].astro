---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.jsx'
export async function getStaticPaths(){
  const m = import.meta.glob('../../../content/projects/*.md', { eager: true });
  return Object.values(m)
    .map(x => {
      const fm = x.frontmatter ?? {};
      const slug = fm.slug ?? (fm.title || '').toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
      return { params: { slug } };
    })
    .filter(entry => entry.params.slug);
}
const { slug } = Astro.params;
const modules = import.meta.glob('../../../content/projects/*.md', { eager: true });
let matched = null;
for (const [p, m] of Object.entries(modules)) {
  const fm = m.frontmatter ?? {};
  const s = fm.slug ?? (fm.title || '').toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
  if (s === slug) { matched = { mod: m, fm }; break; }
}
const Project = matched?.mod?.default;
---
<Layout>
  {Project ? (
    <article class="max-w-4xl mx-auto px-4 py-6">
      {/* Title Header */}
      <div class="mb-8 border-b border-white/5 pb-6">
        <div class="flex items-center gap-2 text-xs font-mono text-zinc-500 mb-2 uppercase tracking-widest">
          <a href="/projects" class="hover:text-accent transition-colors">Projects</a>
          <span>/</span>
          <span class="text-zinc-400">Core_File</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-3 leading-tight">{matched.fm.title}</h1>
        <div class="text-xs font-mono text-zinc-500 flex flex-wrap gap-4">
          {matched.fm.date && (
            <div class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span>Date: {matched.fm.date}</span>
            </div>
          )}
        </div>
      </div>

      {/* Obsidian Properties Panel */}
      <div class="cyber-card p-5 rounded-2xl mb-8 border border-white/5 bg-zinc-950/30 backdrop-blur-md">
        <div class="flex items-center gap-2 mb-4 border-b border-white/5 pb-2">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
          <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-400">Project Metadata</h3>
        </div>
        
        <div class="grid grid-cols-1 gap-3 text-sm">
          {/* Row: Summary */}
          {matched.fm.summary && (
            <div class="flex flex-col gap-1 py-1.5 border-b border-white/5">
              <span class="text-zinc-500 font-mono text-xs flex items-center gap-2">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Summary
              </span>
              <span class="text-zinc-300 font-medium pl-5">{matched.fm.summary}</span>
            </div>
          )}

          {/* Row: Repository */}
          {matched.fm.repo && (
            <div class="flex items-center justify-between py-1.5">
              <span class="text-zinc-500 font-mono text-xs flex items-center gap-2">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Source Code
              </span>
              <a class="text-accent font-semibold flex items-center gap-1 hover:underline hover:text-shadow" href={matched.fm.repo} target="_blank" rel="noopener">
                View Repository
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
          )}
        </div>
      </div>

      {/* Markdown Body */}
      <div class="obsidian-content">
        <Project />
      </div>
    </article>
  ) : (
    <div class="max-w-4xl mx-auto px-4 py-12">
      <h2 class="text-xl font-semibold">Not found</h2>
      <p class="muted">The requested project could not be found.</p>
    </div>
  )}

  <Footer>
</Layout>
