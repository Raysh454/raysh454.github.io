---
import Footer from '../components/Footer.jsx'
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <article class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-10">
      <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-2">About Me</h1>
      <div class="w-16 h-1 bg-accent rounded-full"></div>
    </div>

    <div class="cyber-card p-5 rounded-2xl border border-white/5 bg-zinc-950/50 backdrop-blur-md shadow-2xl font-mono text-sm mb-8">
      {/* Terminal Header */}
      <div class="flex items-center gap-3 mb-6 border-b border-white/5 pb-3">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500/80 shadow-[0_0_8px_rgba(239,68,68,0.4)]"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80 shadow-[0_0_8px_rgba(234,179,8,0.4)]"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80 shadow-[0_0_8px_rgba(34,197,94,0.4)]"></div>
        </div>
        <span class="text-xs text-zinc-500 flex-1 text-center pr-8">guest@system:~</span>
      </div>

      {/* Terminal Body */}
      <div class="text-zinc-300 space-y-8">
        {/* Bio Command */}
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-accent font-bold">~</span>
            <span class="text-zinc-500">$</span>
            <span class="text-zinc-100">cat system/bio.md</span>
          </div>
          <p class="text-zinc-400 leading-relaxed pl-4 border-l-2 border-white/5">
            A software engineer and security researcher specializing in application hardening 
            and native performance optimization. I build cross-platform tools and secure 
            ingestion pipelines, focusing on eliminating application vulnerabilities at the 
            parser level without sacrificing execution velocity.
          </p>
        </div>

        {/* Experience Command */}
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-accent font-bold">~</span>
            <span class="text-zinc-500">$</span>
            <span class="text-zinc-100">cat system/experience.md</span>
          </div>
          <div class="pl-4 border-l-2 border-white/5 space-y-4">
            <div>
              <h3 class="text-white font-bold text-base mb-1"># 10Pearls .NET / React Fullstack Intern</h3>
              <p class="text-zinc-400 leading-relaxed">
                Assisted in the development and maintenance of scalable web applications using .NET Core and React. 
                Collaborated with senior engineers to optimize database queries, implement responsive front-end interfaces, 
                and resolve critical bugs during the development lifecycle.
              </p>
            </div>
          </div>
        </div>
        
        {/* Blinking Cursor */}
        <div class="flex items-center gap-2 pt-4">
          <span class="text-accent font-bold">~</span>
          <span class="text-zinc-500">$</span>
          <span class="w-2.5 h-4 bg-accent/80 animate-pulse inline-block"></span>
        </div>
          {/* Card Footer */}
          <div class="text-center pt-2">
              <Footer>
          </div>
      </div>
    </div>
  </article>
</Layout>
