---
import Layout from '../layouts/Layout.astro';
import path from 'path';
import { parseCustomWriteup } from '../utils/markdown.js';

// Load the complete markdown modules
const projectModules = import.meta.glob('../../content/projects/*.md', { eager: true });
const writeupModules = import.meta.glob('../../content/writeups/*.md', { eager: true });

const latestWriteups = Object.entries(writeupModules)
  .map(([filePath, fileInstance]) => parseCustomWriteup(filePath, fileInstance))
  .filter(w => !w.status.toLowerCase().includes('incomplete'))
  .slice(0, 3);

const featuredProjects = Object.values(projectModules)
  .map(m => m.frontmatter)
  .filter(meta => meta && meta.title)
  .sort((a,b) => new Date(b.date || 0) - new Date(a.date || 0))
  .slice(0,3);

function slugFrom(meta) {
  return meta.slug;
}
---

<Layout>
  <div class="relative w-full max-w-6xl mx-auto px-4 py-8 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      {/* Left Column - Headline & Bio (7 cols on large screens) */}
      <div class="lg:col-span-7 flex flex-col items-start text-left space-y-6">
        
        {/* Animated Pill Status */}
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-accent font-mono text-[11px] uppercase tracking-wider animate-pulse">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          Decryption Pipeline Active
        </div>

        {/* Hero Title */}
        <div class="space-y-2">
          <h2 class="text-4xl md:text-5xl font-extrabold text-zinc-400 tracking-tight">
            Hello, I'm
          </h2>
          <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter leading-none">
            Shehryar Baloch<span class="text-accent">.</span>
          </h1>
        </div>

        {/* Dynamic Tech Subtitle */}
        <div class="space-y-1">
          <h3 class="text-2xl md:text-3xl font-bold text-zinc-100 font-sans">
            Software Engineer
          </h3>
          <p class="text-lg md:text-xl font-mono text-accent font-semibold tracking-wide typing-cursor">
            & Security Researcher
          </p>
        </div>

        {/* Core Pitch Description */}
        <p class="text-base md:text-lg text-zinc-400 leading-relaxed max-w-lg">
            Building high-performance native apps and secure backends. Bridging the gap between deterministic data defenses and runtime performance optimization.
        </p>

        {/* Interactive CTA & Stats Row */}
        <div class="flex flex-wrap gap-4 pt-4 w-full">
          <a href="/projects" class="btn-primary group text-sm font-semibold tracking-wide flex items-center justify-center gap-2">
            Execute Core_Files
            <svg 
              width="14" 
              height="14" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              strokeWidth="2.5" 
              strokeLinecap="round" 
              strokeLinejoin="round"
              className="group-hover:translate-x-1 transition-transform"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
          <a href="/writeups" class="px-6 py-3 rounded-full border border-white/10 text-zinc-300 hover:text-white hover:border-accent/40 bg-white/5 hover:bg-accent/5 font-semibold text-sm transition-all duration-300">
            Read Security_Logs
          </a>
        </div>

        {/* Metadata Details (Cleaned up location SVG) */}
        <div class="flex flex-wrap items-center gap-6 pt-6 text-zinc-500 font-mono text-xs border-t border-white/5 w-full max-w-md">
          <div class="flex items-center gap-1.5">
            <svg 
              width="12" 
              height="12" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              strokeWidth="2" 
              strokeLinecap="round" 
              strokeLinejoin="round"
            >
              <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            IP: 127.0.0.1
          </div>
          <div>•</div>
          <div>STATUS: Deploying patches</div>
        </div>

      </div>

      {/* Right Column - Premium Glass Telemetry Center (5 cols on large screens) */}
      <div class="lg:col-span-5 w-full">
        <div class="cyber-card p-6 md:p-8 rounded-3xl w-full max-w-md mx-auto relative overflow-hidden">
          
          {/* Card Accent Top Bar */}
          <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-6">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-rose-500/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-500/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-accent/80"></span>
            </div>
            <div class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">Sys_Telemetry_v4</div>
          </div>

          {/* Quick Metrics */}
          <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="card-inner py-4 px-2 flex flex-col items-center justify-center">
              <span class="text-2xl md:text-3xl font-extrabold text-accent font-mono tracking-tighter">15+</span>
              <span class="text-[9px] uppercase text-zinc-500 tracking-wider font-semibold mt-1">Projects</span>
            </div>
            <div class="card-inner py-4 px-2 flex flex-col items-center justify-center">
              <span class="text-2xl md:text-3xl font-extrabold text-accent font-mono tracking-tighter">100+</span>
              <span class="text-[9px] uppercase text-zinc-500 tracking-wider font-semibold mt-1">Writeups</span>
            </div>
            <div class="card-inner py-4 px-2 flex flex-col items-center justify-center">
              <span class="text-2xl md:text-3xl font-extrabold text-accent font-mono tracking-tighter">100%</span>
              <span class="text-[9px] uppercase text-zinc-500 tracking-wider font-semibold mt-1">Open_Source</span>
            </div>
          </div>

          {/* Directory Listings / Content Logs */}
          <div class="space-y-4 mb-6">
            
            {/* Featured Projects Sub-Section */}
            <div class="space-y-2">
              <div class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider mb-1">> ls ./featured_projects</div>
              <ul class="space-y-2.5">
                  {featuredProjects.map(p => (
                  <li class="group/item">
                    <a href={`/projects/${slugFrom(p)}`} class="flex items-center justify-between p-2 rounded-lg hover:bg-accent/5 border border-transparent hover:border-accent/10 transition-all duration-200">
                      <span class="text-xs font-mono font-medium text-zinc-200 group-hover/item:text-accent transition-colors">
                        ./{p.title.toLowerCase().replace(/\s+/g,'_')}.sh
                      </span>
                      <svg 
                        width="10" 
                        height="10" 
                        viewBox="0 0 24 24" 
                        fill="none" 
                        stroke="currentColor" 
                        strokeWidth="3" 
                        strokeLinecap="round" 
                        strokeLinejoin="round" 
                        className="text-zinc-600 group-hover/item:text-accent transition-colors"
                      >
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            {/* Latest Writeups Sub-Section */}
            <div class="space-y-2">
              <div class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider mb-1">> tail /var/log/writeups</div>
              <ul class="space-y-2.5">
                {latestWriteups.map(w => (
                  <li class="group/item">
                      <a href={`/writeups/${slugFrom(w)}`} class="flex items-center justify-between p-2 rounded-lg hover:bg-accent/5 border border-transparent hover:border-accent/10 transition-all duration-200">
                      <span class="text-xs font-mono font-medium text-zinc-200 group-hover/item:text-accent transition-colors truncate max-w-[200px]">
                        {w.title}
                      </span>
                      <span class="text-[9px] font-mono text-zinc-600 group-hover/item:text-accent/60">
                        LOG_OK
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

          </div>

          {/* Skill Tag Pills */}
          <div class="flex flex-wrap gap-1.5 justify-center mb-6 pt-4 border-t border-white/5">
            <span class="tech-pill">Go</span>
            <span class="tech-pill">.NET / C#</span>
            <span class="tech-pill">Flutter / Dart</span>
            <span class="tech-pill">Linux</span>
            <span class="tech-pill">Python</span>
            <span class="tech-pill">App_Sec</span>
          </div>

          {/* Card Footer */}
          <div class="text-center pt-2">
            <p class="text-[10px] text-zinc-500 font-mono tracking-widest uppercase">
              // Security Architecture Redefined
            </p>
          </div>

        </div>
      </div>

    </div>
  </div>
</Layout>
